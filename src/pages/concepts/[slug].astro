---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Locator from '../../components/Locator.astro';
import map from '../../data/map.json';
import islands from '../../data/islands.json';
import SpectrumExplorer from '../../components/islands/SpectrumExplorer.astro';
import StrikingSlider from '../../components/islands/StrikingSlider.astro';
import AlexandriteToggle from '../../components/islands/AlexandriteToggle.astro';
import LycurgusFlip from '../../components/islands/LycurgusFlip.astro';

export async function getStaticPaths() {
  const entries = await getCollection('concepts');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const order = [
  map.anchorSlug,
  ...map.mechanisms.flatMap((m) => m.slugs),
  map.crosscutting.slug,
  map.craft.slug,
];
const idx = order.indexOf(entry.id);
const prev = idx > 0 ? order[idx - 1] : null;
const next = idx >= 0 && idx < order.length - 1 ? order[idx + 1] : null;
---
<Base title={entry.data.title} description={entry.data.summary}>
  <article class="concept">
    <Locator slug={entry.id} mechanism={entry.data.mechanism} />
    <p class="detail-type">{entry.data.mechanism}</p>
    <h1>{entry.data.title}</h1>
    <p class="summary">{entry.data.summary}</p>
    <Content />
    {entry.id in islands.spectrum && <SpectrumExplorer colorants={islands.spectrum[entry.id as keyof typeof islands.spectrum]} />}
    {entry.id in islands.striking && <StrikingSlider sequence={islands.striking[entry.id as keyof typeof islands.striking]} />}
    {(islands.lycurgus as string[]).includes(entry.id) && <LycurgusFlip />}
    {(islands.alexandrite as string[]).includes(entry.id) && <AlexandriteToggle />}
    {entry.data.sources && entry.data.sources.length > 0 && (
      <section class="sources">
        <h2>Further reading</h2>
        <ul>
          {entry.data.sources.map((s) => (
            <li><a href={s.url} target="_blank" rel="noopener">{s.label}</a></li>
          ))}
        </ul>
      </section>
    )}
    <nav class="prevnext">
      {prev && <a href={`${base}/concepts/${prev}/`}>← {prev.replace(/-/g, ' ')}</a>}
      {next && <a href={`${base}/concepts/${next}/`} class="next">{next.replace(/-/g, ' ')} →</a>}
    </nav>
    <p class="back"><a href={`${base}/`}>← back to the map</a></p>
  </article>
</Base>
<style>
  .prevnext { display: flex; justify-content: space-between; margin-top: 2rem; font-size: 0.85rem; }
  .prevnext .next { margin-left: auto; }
</style>
