---
// props: colorants — comma-separated colorant ids (empty = all)
// Note: the SVG gradient uses id="vis". If two SpectrumExplorer instances ever
// appeared on the same page they would collide; in this site each concept page
// gets at most one instance, so this is acceptable.
const { colorants = '' } = Astro.props;
---
<figure class="spx" data-colorants={colorants}>
  <div class="spx-buttons"></div>
  <div class="spx-stage">
    <svg viewBox="0 0 360 90" class="spx-svg" role="img" aria-label="absorption curve over the visible spectrum">
      <defs>
        <linearGradient id="vis" x1="0" x2="1" y1="0" y2="0">
          <stop offset="0%" stop-color="#610061"/><stop offset="12%" stop-color="#3b00b8"/>
          <stop offset="28%" stop-color="#007bff"/><stop offset="44%" stop-color="#00c853"/>
          <stop offset="58%" stop-color="#ffe600"/><stop offset="74%" stop-color="#ff8c00"/>
          <stop offset="100%" stop-color="#c40000"/>
        </linearGradient>
      </defs>
      <rect x="0" y="0" width="360" height="90" fill="url(#vis)" opacity="0.85"/>
      <polyline class="spx-curve" fill="none" stroke="#111" stroke-width="2.5" points=""/>
    </svg>
    <div class="spx-swatch" title="transmitted color"></div>
  </div>
  <figcaption><span class="spx-why"></span></figcaption>
  <p class="island-footnote">Curves are illustrative approximations and the swatch is a coarse RGB rendering, not a full CIE colorimetric pipeline.</p>
</figure>
<script>
  import optics from '../../data/optics.json';
  import { initSpectrumExplorer } from '../../scripts/islands/spectrum.js';
  for (const el of document.querySelectorAll('.spx')) initSpectrumExplorer(el, optics);
</script>
<style>
  .spx { border: 1px solid var(--edge); border-radius: 12px; padding: 1rem; margin: 1.5rem 0; background: var(--panel); }
  .spx-buttons { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.7rem; }
  .spx-buttons button { font-size: 0.78rem; padding: 0.25rem 0.6rem; border-radius: 999px;
    border: 1px solid var(--edge); background: var(--node); color: var(--muted); cursor: pointer;
    transition: color .15s, border-color .15s, background .15s; }
  .spx-buttons button:hover { color: var(--text); border-color: var(--faint); }
  .spx-buttons button.active { background: var(--accent); color: var(--bg); border-color: var(--accent); }
  .spx-stage { display: flex; gap: 0.8rem; align-items: center; }
  .spx-svg { flex: 1; border-radius: 8px; }
  .spx-swatch { width: 3.4rem; height: 3.4rem; border-radius: 10px; border: 2px solid var(--edge);
    box-shadow: inset 0 0 12px rgba(255,255,255,0.35); }
  figcaption { margin-top: 0.5rem; font-size: 0.88rem; color: var(--muted); }
  .island-footnote { font-size: 0.72rem; color: var(--faint); margin: 0.5rem 0 0; }
</style>
