---
import map from '../data/map.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = (slug: string, anchor: string | null) => `${base}/concepts/${slug}/${anchor ? `#${anchor}` : ''}`;
---
<div class="glass-map">
  <a class="map-anchor" href={href(map.anchorSlug, null)}>
    <span class="map-title">{map.title}</span>
    <span class="map-sub">start here: the four mechanisms</span>
  </a>

  <div class="mechanisms">
    {map.mechanisms.map((m) => (
      <section class="mechanism" style={`--theme:${m.theme}`}>
        {m.slugs[0] ? (
          <a class="mech-label" href={href(m.slugs[0], null)}>{m.label}</a>
        ) : (
          <a class="mech-label" href={href(m.anchorTarget.targetSlug, m.anchorTarget.anchor)}>{m.label}</a>
        )}
        <p class="mech-blurb">{m.blurb}</p>
        {m.slugs.length > 1 && (
          <p class="mech-also">also: <a href={href(m.slugs[1], null)}>{m.slugs[1].replace(/-/g, ' ')}</a></p>
        )}
        <div class="swatches">
          {m.artifacts.map((a) => (
            <a class="swatch" href={href(a.targetSlug, a.anchor)} style={`background:${a.colorCss}`} title={a.label} aria-label={a.label}></a>
          ))}
        </div>
      </section>
    ))}
  </div>

  <a class="crosscut" href={href(map.crosscutting.slug, null)}>{map.crosscutting.label}</a>
  <a class="craft" href={href(map.craft.slug, null)}>{map.craft.label}</a>
</div>

<style>
  .glass-map { max-width: 56rem; margin: 0 auto; display: grid; gap: 0.9rem; padding: 1.5rem 1rem; }
  .map-anchor { text-align: center; padding: 1rem; border: 2px solid var(--edge); border-radius: 12px; text-decoration: none; color: var(--text); transition: border-color .15s; }
  .map-anchor:hover { border-color: var(--accent); }
  .map-title { display: block; font-size: 1.5rem; font-weight: 700; }
  .map-sub { font-size: 0.85rem; color: var(--muted); }
  .mechanisms { display: grid; grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr)); gap: 0.9rem; }
  .mechanism { border: 1.5px solid var(--theme); border-radius: 12px; padding: 0.9rem; background: var(--panel); }
  .mech-label { font-weight: 700; color: var(--theme); text-decoration: none; font-size: 1.05rem; }
  .mech-label:hover { opacity: 0.85; }
  .mech-blurb { font-size: 0.85rem; margin: 0.4rem 0; color: var(--muted); }
  .mech-also { font-size: 0.78rem; color: var(--faint); margin: 0.2rem 0; }
  .mech-also a { color: var(--muted); }
  .mech-also a:hover { color: var(--text); }
  .swatches { display: flex; gap: 0.45rem; margin-top: 0.6rem; flex-wrap: wrap; }
  .swatch { width: 2.4rem; height: 2.4rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.12); transition: transform 0.12s; display: block; }
  .swatch:hover { transform: scale(1.12); }
  .crosscut, .craft { text-align: center; padding: 0.55rem; border: 1.5px dashed var(--faint); border-radius: 10px; font-size: 0.9rem; text-decoration: none; color: var(--muted); transition: color .15s, border-color .15s; }
  .crosscut:hover, .craft:hover { color: var(--text); border-color: var(--muted); }
</style>
